# 🌍 PlanetPulse - Datenbank-Konfiguration (VORLAGE)
# Kopiere diese Datei als 'application.properties' und fülle die Daten aus.

# 1. JDBC Verbindung (MySQL)
# Ersetze 'localhost:3306' und 'planetpulse_db' ggf. durch deine lokalen Werte.
spring.datasource.url=jdbc:mysql://localhost:3306/planetpulse_db?createDatabaseIfNotExist=true&serverTimezone=UTC
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# 2. Authentifizierung
# Hier deinen MySQL-User und das Passwort eintragen.
spring.datasource.username=root
spring.datasource.password=DEIN_PASSWORT

# 3. JPA / Hibernate (Tabellen-Automatisierung)
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# 4. Server-Port (Standard: 8080)
server.port=8080